generator client {
  provider      = "prisma-client-js"
  output        = "../server/generated/prisma"
  binaryTargets = ["native", "windows", "darwin-arm64"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Brand {
  userId      String @id @db.Uuid
  name        String @db.VarChar(50)
  description String @db.VarChar(255)
  url         String @db.VarChar(255)
  logoId      String @db.Uuid

  user  user   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item  Item[] @relation("BrandItem")
  files Files  @relation("BrandProfilePicture", fields: [logoId], references: [id])

  @@index([userId], map: "idx_brand_user_id")
  @@map("Brand")
}

model Client {
  userId      String    @id @db.Uuid
  name        String    @db.VarChar(50)
  dateOfBirth DateTime? @db.Timestamp(6)
  preferences Json?
  user        user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_client_user_id")
  @@map("Client")
}

model ItemFavorite {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  itemUuid  String    @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item      Item      @relation("ItemFavorites", fields: [itemUuid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, itemUuid])
  @@index([itemUuid], map: "idx_item_favorites_item")
  @@index([userId], map: "idx_item_favorites_user")
  @@map("ItemFavorite")
}

model ItemLike {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @db.Uuid
  itemUuid  String    @db.Uuid
  createdAt DateTime? @default(now()) @db.Timestamp(6)
  user      user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  item      Item      @relation("ItemLikes", fields: [itemUuid], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([userId, itemUuid])
  @@index([itemUuid], map: "idx_item_likes_item")
  @@index([userId], map: "idx_item_likes_user")
  @@map("ItemLike")
}

model RegisterInProgress {
  id                         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String @unique @db.Uuid
  verificationCode           String @db.VarChar(6)
  verificationCodeExpiration String @db.VarChar(30)
  token                      String @unique
  user                       user   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_register_in_progress_user_id")
  @@map("RegisterInProgress")
}

model ResetPasswordInProgress {
  id                         String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId                     String @unique @db.Uuid
  verificationCode           String @db.VarChar(6)
  verificationCodeExpiration String @db.VarChar(30)
  token                      String @unique
  user                       user   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([userId], map: "idx_reset_password_in_progress_user_id")
  @@map("ResetPasswordInProgress")
}

model InspoItems {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  itemUuid String @db.Uuid
  category String @db.VarChar(255)
  index    Int    @db.Integer

  item Item @relation("InspoItem", fields: [itemUuid], references: [id])

  @@map("InspoItems")
}

model Item {
  id          String @id @default(uuid())
  name        String @db.VarChar(50)
  description String @db.VarChar(512)
  price       Int    @db.Integer
  url         String @db.VarChar(255)
  brandId     String @db.Uuid
  imageId     String @db.Uuid

  brand      Brand          @relation("BrandItem", fields: [brandId], references: [userId])
  files      Files          @relation("ItemPicture", fields: [imageId], references: [id])
  favorites  ItemFavorite[] @relation("ItemFavorites")
  likes      ItemLike[]     @relation("ItemLikes")
  inspoItems InspoItems[]   @relation("InspoItem")
}

model Files {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  contentType String
  bucket      String
  url         String
  uploadUrl   String
  metadata    Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand Brand[] @relation("BrandProfilePicture")
  item  Item[]  @relation("ItemPicture")
}

model account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String    @db.Uuid
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime? @db.Timestamp(6)
  refreshTokenExpiresAt DateTime? @db.Timestamp(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @db.Timestamp(6)
  updatedAt             DateTime  @db.Timestamp(6)
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model session {
  id        String   @id
  expiresAt DateTime @db.Timestamp(6)
  token     String   @unique
  createdAt DateTime @db.Timestamp(6)
  updatedAt DateTime @db.Timestamp(6)
  ipAddress String?
  userAgent String?
  userId    String   @db.Uuid
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model user {
  id            String    @id @db.Uuid
  name          String
  email         String    @unique
  emailVerified Boolean
  image         String?
  createdAt     DateTime  @default(now()) @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @db.Timestamp(6)
  userType      String    @default("client")
  account       account[]
  session       session[]

  // Relations
  brand                   Brand?
  client                  Client?
  itemFavorites           ItemFavorite[]
  itemLikes               ItemLike[]
  RegisterInProgress      RegisterInProgress[]
  ResetPasswordInProgress ResetPasswordInProgress[]
}

model verification {
  id         String    @id
  identifier String
  value      String
  expiresAt  DateTime  @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @db.Timestamp(6)
}

// Seed configuration
// Run: npm run db:seed
